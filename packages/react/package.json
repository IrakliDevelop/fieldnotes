{
  "name": "@fieldnotes/react",
  "version": "0.2.1",
  "description": "React wrapper for Field Notes canvas SDK",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrakliDevelop/fieldnotes.git",
    "directory": "packages/react"
  },
  "bugs": {
    "url": "https://github.com/IrakliDevelop/fieldnotes/issues"
  },
  "homepage": "https://github.com/IrakliDevelop/fieldnotes/tree/master/packages/react#readme",
  "keywords": [
    "canvas",
    "infinite-canvas",
    "react",
    "html-embedding",
    "fieldnotes"
  ],
  "dependencies": {
    "@fieldnotes/core": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
