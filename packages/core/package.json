{
  "name": "@fieldnotes/core",
  "version": "0.2.1",
  "description": "Vanilla TypeScript infinite canvas engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
