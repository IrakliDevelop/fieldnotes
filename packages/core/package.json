    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
