{
  "name": "@fieldnotes/core",
  "version": "0.3.0",
  "description": "Vanilla TypeScript infinite canvas engine",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrakliDevelop/fieldnotes.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/IrakliDevelop/fieldnotes/issues"
  },
  "homepage": "https://github.com/IrakliDevelop/fieldnotes/tree/master/packages/core#readme",
  "keywords": [
    "canvas",
    "infinite-canvas",
    "drawing",
    "html-embedding",
    "typescript",
    "sdk"
  ],
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
