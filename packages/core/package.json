{
  "name": "@fieldnotes/core",
  "version": "0.40.1",
  "description": "Vanilla TypeScript infinite canvas engine",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:all": "vitest run --coverage",
    "e2e": "playwright test --config e2e/playwright.config.ts",
    "e2e:update": "playwright test --config e2e/playwright.config.ts --update-snapshots"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrakliDevelop/fieldnotes.git",
    "directory": "packages/core"
  },
  "bugs": {
    "url": "https://github.com/IrakliDevelop/fieldnotes/issues"
  },
  "homepage": "https://github.com/IrakliDevelop/fieldnotes/tree/master/packages/core#readme",
  "keywords": [
    "canvas",
    "infinite-canvas",
    "drawing",
    "html-embedding",
    "typescript",
    "sdk"
  ],
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@vitest/coverage-v8": "^4.1.0",
    "jsdom": "^29.0.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
