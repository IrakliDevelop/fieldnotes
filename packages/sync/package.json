{
  "name": "@fieldnotes/sync",
  "version": "0.5.1",
  "description": "Real-time element sync for Field Notes canvas SDK",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/IrakliDevelop/fieldnotes.git",
    "directory": "packages/sync"
  },
  "bugs": {
    "url": "https://github.com/IrakliDevelop/fieldnotes/issues"
  },
  "homepage": "https://github.com/IrakliDevelop/fieldnotes/tree/master/packages/sync#readme",
  "keywords": [
    "canvas",
    "infinite-canvas",
    "realtime",
    "sync",
    "collaboration",
    "fieldnotes"
  ],
  "peerDependencies": {
    "@fieldnotes/core": ">=0.46.0 <1.0.0"
  },
  "devDependencies": {
    "@fieldnotes/core": "workspace:*",
    "@vitest/coverage-v8": "^4.1.0",
    "tsup": "^8.5.1",
    "vitest": "^4.1.0"
  }
}
